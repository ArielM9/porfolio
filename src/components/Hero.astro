<section
  class="col-span-12 lg:col-span-full window-border bg-surface-dark p-8 flex flex-col justify-center min-h-[400px]"
>
  <div class="mono-text mb-6 flex items-center gap-2 text-primary text-sm">
    <span class="opacity-50">dev@arielm:</span><span class="opacity-80">~</span
    ><span class="text-white">$</span>
    <span class="inline-block w-2 h-5 bg-primary ml-1 animate-pulse"></span>
  </div>
  <h1 class="mono-text text-4xl md:text-6xl font-bold leading-tight mb-6">
    Desarrollador Web<br />
    <span class="text-primary">Full Stack.</span>
  </h1>
  <p class="text-text-muted max-w-xl text-lg leading-relaxed mb-8">
    Desarrollador web con enfoque en el ecosistema JavaScript/TypeScript y
    tecnologías frontend (React/Next.js). Administrador de mis propios servidores
    Linux, con perfil analítico y resolutivo.
  </p>
  <div class="flex gap-4">
    <button
      onclick="document.getElementById('projects').scrollIntoView({behavior: 'smooth'})"
      class="mono-text border border-primary text-primary px-6 py-3 text-sm hover:bg-primary hover:text-background-dark transition-all cursor-pointer"
    >
      ver_proyectos.sh
    </button>
    <a
      href="/cv.pdf"
      download="cv-ariel-marchegiani.pdf"
      class="mono-text border border-border-zinc px-6 py-3 text-sm hover:border-text-main transition-all"
    >
      descargar_cv.pdf
    </a>
  </div>
</section>
